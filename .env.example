# Setrox Platform - Environment Variables
# Copy to .env and fill in your real values
# DO NOT commit the .env file

# ============ Core ============
NODE_ENV=development

# ============ Database ============
POSTGRES_USER=setrox
POSTGRES_PASSWORD=setrox_password
POSTGRES_DB=setrox_db
DATABASE_URL=postgresql://setrox:setrox_password@localhost:5432/setrox_db?schema=public

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ JWT (CHANGE THESE!) ============
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-hex-chars-32-bytes-jwt-secret
JWT_REFRESH_SECRET=replace-with-64-hex-chars-32-bytes-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ============ CORS ============
# Comma-separated list. * for development only.
CORS_ORIGIN=https://admin.setrox.com.tr,https://lens.setrox.com.tr

# ============ Encryption (CHANGE!) ============
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============ Admin Bootstrap ============
ADMIN_EMAIL=admin@setrox.com.tr
ADMIN_PASSWORD=ChangeThisImmediately!

# ============ Default AI Provider Keys (Optional) ============
# These can also be set via Admin panel after first run.
GEMINI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=

# ============ Production ============
# When deploying to Dokploy, override:
# - DATABASE_URL → internal postgres service
# - REDIS_URL → internal redis service
# - CORS_ORIGIN → your actual domains
# - JWT_SECRET, JWT_REFRESH_SECRET, ENCRYPTION_KEY → strong random
